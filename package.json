{
  "name": "@bemedev/dev-utils",
  "version": "0.1.1",
  "description": "A collection of utilities for Node.js development, including build tools, testing utilities, and configuration management.",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/node-dev-utils"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "types": "./lib/index.d.ts"
    },
    "./build-tests": {
      "import": "./lib/build-tests/cli/index.js",
      "require": "./lib/build-tests/cli/index.cjs",
      "types": "./lib/build-tests/cli/index.d.ts"
    },
    "./rolldown": {
      "import": "./lib/rolldown-config/index.js",
      "require": "./lib/rolldown-config/index.cjs",
      "types": "./lib/rolldown-config/index.d.ts"
    },
    "./vitest-alias": {
      "import": "./lib/vitest-alias/index.js",
      "require": "./lib/vitest-alias/index.cjs",
      "types": "./lib/vitest-alias/index.d.ts"
    },
    "./vitest-exclude": {
      "import": "./lib/vitest-exclude/index.js",
      "require": "./lib/vitest-exclude/index.cjs",
      "types": "./lib/vitest-exclude/index.d.ts"
    },
    "./vitest-extended": {
      "import": "./lib/vitest-extended/index.js",
      "require": "./lib/vitest-extended/index.cjs",
      "types": "./lib/vitest-extended/index.d.ts"
    }
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "node",
    "utilities",
    "build-tools",
    "testing",
    "configuration",
    "typescript",
    "rollup",
    "vitest"
  ],
  "files": [
    "lib",
    "public"
  ],
  "bin": {
    "build-tests": "lib/build-tests/cli/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade:fast && pnpm run ci",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "config:fast": "pnpm add -D @vitest/coverage-v8@3.2.4 @vitest/ui@3.2.4 vitest@3.2.4 @bemedev/app-ts@2.3.0 @bemedev/basifun@0.5.3",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "p-q": "pretty-quick",
    "posttest": "pnpm run fmt && tsx ./src/build-tests/cli/index.ts post && echo \"\n✅ Tests completed successfully\n\"",
    "prepare": "husky",
    "prepublishOnly": "",
    "pretest": "pnpm run build && node ./lib/build-tests/cli/index.js pre",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "test:coverage": "vitest run",
    "test": "pnpm run test:coverage",
    "test:no-type": "pnpm run test:coverage -c \"vitest.config.notype.ts\" --no-coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:type": "pnpm run test:coverage -c \"vitest.config.type.ts\" --no-coverage",
    "test:type:watch": "vitest -c \"vitest.config.type.ts\"",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package && pnpm run config:fast",
    "size": "size-limit",
    "upgrade:fast": "pnpm up --latest && pnpm run config:fast"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "dependencies": {
    "cmd-ts": "^0.15.0",
    "edit-json-file": "^1.8.1",
    "glob": "^13.0.6",
    "rollup-plugin-circular-dependencies": "^2.0.1",
    "rollup-plugin-node-externals": "^8.1.2",
    "rollup-plugin-tsc-alias": "^1.1.4",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "shelljs": "^0.10.0",
    "sort-keys": "^6.0.0",
    "tsc-alias": "^1.8.16"
  },
  "devDependencies": {
    "@bemedev/app-ts": "2.3.0",
    "@bemedev/basifun": "0.5.3",
    "@size-limit/file": "^12.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/edit-json-file": "^1.7.4",
    "@types/node": "^25.5.0",
    "@types/shelljs": "^0.10.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "is-in-ci": "^2.0.0",
    "jsdom": "^29.0.1",
    "onchange": "^7.1.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0-rc.12",
    "rxjs": "^7.8.2",
    "size-limit": "^12.0.1",
    "solid-js": "^1.9.12",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "3.2.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^6.0.2",
    "vitest": "3.2.4"
  }
}
