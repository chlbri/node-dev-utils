{
  "name": "@bemedev/dev-utils-monorepo",
  "private": true,
  "description": "Monorepo workspace root for dev-utils",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/node-dev-utils"
  },
  "license": "MIT",
  "type": "module",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "pnpm:devPreinstall": "node -e \"const fs=require('fs'); const pkg=JSON.parse(fs.readFileSync('./package.json')); const version=require('child_process').execSync('pnpm -v').toString().trim(); pkg.packageManager='pnpm@' + version; fs.writeFileSync('./package.json', JSON.stringify(pkg, null, 2) + '\\n');\"",
    "build": "pnpm -r --sort run build",
    "config": "pnpm i",
    "_ci": "pnpm install && pnpm -r --sort run _ci",
    "ci": "CI=$(date +%s) && pnpm run _ci && echo \"\\n✅ CI takes $(($(date +%s) - CI))s\\n\"",
    "ci:admin": "CI_ADMIN=$(date +%s) && pnpm run rm && pnpm run up && pnpm run _ci && echo \"\\n✅ Admin CI takes $(($(date +%s) - CI_ADMIN))s\\n\"",
    "rimraf": "pnpx rimraf -rf",
    "rinit": "pnpm run rm && pnpm run config",
    "lint": "oxlint --fix && oxfmt",
    "test": "vitest run",
    "pretest": "pnpm run -r pretest",
    "posttest": "pnpm run -r posttest",
    "test:only": "pnpm run test --no-coverage",
    "rm": "pnpm clean lockfile && pnpx rimraf node_modules **/node_modules",
    "up": "pnpm -r update --latest",
    "prepare": "husky",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "@bemedev/app-ts": "3.0.2",
    "@bemedev/basifun": "0.5.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/file": "^12.1.0",
    "@types/edit-json-file": "^1.7.4",
    "@types/node": "^26.0.1",
    "@types/shelljs": "^0.10.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "is-in-ci": "^2.0.0",
    "onchange": "^7.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.1.3",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@11.7.0"
}
